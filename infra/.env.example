# === DairyAI Environment Variables ===
# Copy this file to the repo root as .env:  cp infra/.env.example ../.env

# -- Database (use localhost for local dev, postgres for Docker) --
DATABASE_URL=postgresql+asyncpg://dairy:dairy123@localhost:5432/dairy_ai
REDIS_URL=redis://localhost:6379/0

# -- Auth --
JWT_SECRET=change-me-in-production-use-long-random-string
JWT_ALGORITHM=HS256

# -- WhatsApp Business Cloud API --
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=dairy-ai-webhook-verify

# -- Agora (video consultations) --
AGORA_APP_ID=
AGORA_APP_CERTIFICATE=

# -- Bhashini (Indian language STT/TTS) --
BHASHINI_API_KEY=
BHASHINI_USER_ID=

# -- LLM --
LLM_API_URL=http://localhost:11434/v1
LLM_API_KEY=
LLM_MODEL=llama3

# -- MQTT (use localhost for local dev, mosquitto for Docker) --
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# -- AWS S3 --
AWS_ACCESS_KEY=
AWS_SECRET_KEY=
S3_BUCKET=dairy-ai-uploads

# -- Razorpay --
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# -- Pashudhan / INAPH --
PASHUDHAN_API_URL=https://inaph.gov.in/api/v1
PASHUDHAN_API_KEY=

# -- Firebase FCM (push notifications) --
FCM_SERVER_KEY=
FCM_PROJECT_ID=

# -- SMS Gateway --
SMS_PROVIDER=msg91
SMS_API_KEY=
SMS_SENDER_ID=DRYAI

# -- Logging --
LOG_LEVEL=INFO
CORS_ORIGINS=*
